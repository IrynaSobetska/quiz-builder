generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum QuestionType {
  BOOLEAN
  INPUT
  CHECKBOX
}

model Quiz {
  id        String     @id @default(cuid())
  title     String
  questions Question[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Question {
  id        String       @id @default(cuid())
  quizId    String
  quiz      Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type      QuestionType
  prompt    String
  position  Int
  options   Json?
  answer    Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}